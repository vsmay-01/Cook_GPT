# ============================================
# Groq API Configuration (LLM - Chat Generation)
# ============================================
# Get your API key from: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Optional: Specify the Groq model to use
# Default is "llama-3.1-8b-instant" if not specified
GROQ_MODEL=llama-3.1-8b-instant

# ============================================
# Pinecone Configuration (Vector Database)
# ============================================
# Get your API key from: https://www.pinecone.io
PINECONE_API_KEY=your_pinecone_api_key_here

# ============================================
# Gemini Embeddings Configuration
# ============================================
# Get your API key from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Optional: keep EMBEDDING_DIMENSION=384 if you already have Pinecone
# indexes created by this app and do not want to recreate them.
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-001
EMBEDDING_DIMENSION=384

# ============================================
# Architecture Summary (Hosted Embeddings)
# ============================================
# Embeddings: Gemini API
#    - Hosted embeddings reduce backend memory usage
#    - Configured for 384-dimensional vectors to match Pinecone indexes
#
# LLM: Groq API
#    - Free tier available
#    - Ultra-fast inference
#    - Excellent for RAG tasks
#
# Vector Storage: Pinecone
#    - Stores 384-dimensional embeddings
#    - Serverless, scalable
#    - Namespace-based organization
