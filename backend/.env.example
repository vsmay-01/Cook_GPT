# ============================================
# Groq API Configuration (LLM - Chat Generation)
# ============================================
# Get your API key from: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Optional: Specify the Groq model to use
# Default is "llama-3.1-8b-instant" if not specified
GROQ_MODEL=llama-3.1-8b-instant

# ============================================
# Pinecone Configuration (Vector Database)
# ============================================
# Get your API key from: https://www.pinecone.io
PINECONE_API_KEY=your_pinecone_api_key_here

# ============================================
# Architecture Summary (Hybrid Approach)
# ============================================
# ✅ Embeddings: HuggingFace (sentence-transformers/all-MiniLM-L6-v2)
#    - Local, fast, 384-dimensional vectors
#    - No API calls needed for embeddings
#    - Perfect for RAG applications
#
# ✅ LLM: Groq API (llama3-8b-8192)
#    - Free tier available
#    - Ultra-fast inference
#    - Excellent for RAG tasks
#
# ✅ Vector Storage: Pinecone
#    - Stores 384-dimensional embeddings
#    - Serverless, scalable
#    - Namespace-based organization
